{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://repo-prod.prod.sagebase.org/repo/v1/schema/type/registered/org.synapse.modelxchange-technicalspecifications",
  "title": "Hugging Face Technical Specifications Module",
  "description": "Derived from https://raw.githubusercontent.com/huggingface/huggingface_hub/refs/heads/main/src/huggingface_hub/templates/modelcard_template.md, heading '## Technical Specifications [optional]'. This is an optional section in the original template.",
  "type": "object",
  "definitions": {
    "modelSpecs": {
      "type": "object",
      "properties": {
        "model_specs": {
          "type": "string",
          "description": "Model architecture and objective details.",
          "default": "[More Information Needed]"
        }
      }
    },
    "computeInfrastructure": {
      "type": "object",
      "properties": {
        "compute_infrastructure": {
          "type": "string",
          "description": "Description of the compute infrastructure.",
          "default": "[More Information Needed]"
        }
      }
    },
    "hardwareRequirements": {
      "type": "object",
      "properties": {
        "hardware_requirements": {
          "type": "string",
          "description": "Hardware requirements or hardware details.",
          "default": "[More Information Needed]"
        }
      }
    },
    "software": {
      "type": "object",
      "properties": {
        "software": {
          "type": "string",
          "description": "Software stack or software requirements.",
          "default": "[More Information Needed]"
        }
      }
    }
  },
  "allOf": [
    {
      "$ref": "#/definitions/modelSpecs"
    },
    {
      "$ref": "#/definitions/computeInfrastructure"
    },
    {
      "$ref": "#/definitions/hardwareRequirements"
    },
    {
      "$ref": "#/definitions/software"
    }
  ]
}
