{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hugging Face Model Card Template Data",
  "description": "JSON Schema for the template variables used by huggingface_hub/templates/modelcard_template.md, grouped into subschemas that mirror the template headings.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "modelSources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repo": {
          "type": "string",
          "description": "Optional repository URL or reference.",
          "default": "[More Information Needed]"
        },
        "paper": {
          "type": "string",
          "description": "Optional paper URL or citation reference.",
          "default": "[More Information Needed]"
        },
        "demo": {
          "type": "string",
          "description": "Optional demo URL or description.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "repo"
      ]
    },
    "modelDetails": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_description": {
          "type": "string",
          "description": "Long-form description of the model.",
          "default": ""
        },
        "developers": {
          "allOf": [
            {
              "$ref": "#/definitions/stringArray"
            }
          ],
          "description": "Person, team, or organization that developed the model.",
          "default": [
            "[More Information Needed]"
          ]
        },
        "funded_by": {
          "allOf": [
            {
              "$ref": "#/definitions/stringArray"
            }
          ],
          "description": "Optional funding source for the model.",
          "default": [
            "[More Information Needed]"
          ]
        },
        "shared_by": {
          "allOf": [
            {
              "$ref": "#/definitions/stringArray"
            }
          ],
          "description": "Optional person, team, or organization that shared the model.",
          "default": [
            "[More Information Needed]"
          ]
        },
        "model_type": {
          "type": "string",
          "description": "Model family or task type.",
          "default": "[More Information Needed]"
        },
        "language": {
          "allOf": [
            {
              "$ref": "#/definitions/stringArray"
            }
          ],
          "description": "Language or languages relevant to the model.",
          "default": [
            "[More Information Needed]"
          ]
        },
        "license": {
          "type": "string",
          "description": "License identifier or license text reference.",
          "default": "[More Information Needed]"
        },
        "base_model": {
          "allOf": [
            {
              "$ref": "#/definitions/stringArray"
            }
          ],
          "description": "Optional source model used for fine-tuning or adaptation.",
          "default": [
            "[More Information Needed]"
          ]
        },
        "model_sources": {
          "$ref": "#/definitions/modelSources"
        }
      },
      "required": [
        "model_description",
        "developers",
        "model_type",
        "language",
        "license"
      ]
    },
    "uses": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "direct_use": {
          "type": "string",
          "description": "Primary intended uses of the model.",
          "default": "[More Information Needed]"
        },
        "downstream_use": {
          "type": "string",
          "description": "Optional downstream or derivative use cases.",
          "default": "[More Information Needed]"
        },
        "out_of_scope_use": {
          "type": "string",
          "description": "Uses that should be considered out of scope.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "direct_use",
        "out_of_scope_use"
      ]
    },
    "biasRisksAndLimitations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bias_risks_limitations": {
          "type": "string",
          "description": "Known biases, risks, or limitations.",
          "default": "[More Information Needed]"
        },
        "bias_recommendations": {
          "type": "string",
          "description": "Recommendations for safe or appropriate use.",
          "default": "Users (both direct and downstream) should be made aware of the risks, biases and limitations of the model. More information needed for further recommendations."
        }
      },
      "required": [
        "bias_risks_limitations",
        "bias_recommendations"
      ]
    },
    "howToGetStartedWithTheModel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "get_started_code": {
          "type": "string",
          "description": "Code snippet or instructions for getting started with the model.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "get_started_code"
      ]
    },
    "trainingProcedure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preprocessing": {
          "type": "string",
          "description": "Optional preprocessing details.",
          "default": "[More Information Needed]"
        },
        "training_regime": {
          "type": "string",
          "description": "Training procedure or regime summary.",
          "default": "[More Information Needed]"
        },
        "speeds_sizes_times": {
          "type": "string",
          "description": "Optional training or inference speeds, model sizes, or timing information.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "training_regime"
      ]
    },
    "trainingDetails": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "training_data": {
          "type": "string",
          "description": "Description of the training data.",
          "default": "[More Information Needed]"
        },
        "training_procedure": {
          "$ref": "#/definitions/trainingProcedure"
        }
      },
      "required": [
        "training_data",
        "training_procedure"
      ]
    },
    "testingDataFactorsAndMetrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "testing_data": {
          "type": "string",
          "description": "Description of testing or evaluation data.",
          "default": "[More Information Needed]"
        },
        "testing_factors": {
          "type": "string",
          "description": "Factors considered during evaluation.",
          "default": "[More Information Needed]"
        },
        "testing_metrics": {
          "type": "string",
          "description": "Metrics used to evaluate the model.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "testing_data",
        "testing_factors",
        "testing_metrics"
      ]
    },
    "evaluationResults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "results": {
          "type": "string",
          "description": "Detailed evaluation results.",
          "default": "[More Information Needed]"
        },
        "results_summary": {
          "type": "string",
          "description": "Short summary of evaluation results.",
          "default": ""
        }
      },
      "required": [
        "results",
        "results_summary"
      ]
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "testing_data_factors_and_metrics": {
          "$ref": "#/definitions/testingDataFactorsAndMetrics"
        },
        "results": {
          "$ref": "#/definitions/evaluationResults"
        }
      },
      "required": [
        "testing_data_factors_and_metrics",
        "results"
      ]
    },
    "modelExamination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_examination": {
          "type": "string",
          "description": "Optional analysis or examination of model behavior.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "model_examination"
      ]
    },
    "environmentalImpact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hardware_type": {
          "type": "string",
          "description": "Hardware used for training or relevant environmental impact estimates.",
          "default": "[More Information Needed]"
        },
        "hours_used": {
          "type": "string",
          "description": "Hours of compute used.",
          "default": "[More Information Needed]"
        },
        "cloud_provider": {
          "type": "string",
          "description": "Cloud provider used, if applicable.",
          "default": "[More Information Needed]"
        },
        "cloud_region": {
          "type": "string",
          "description": "Cloud region used, if applicable.",
          "default": "[More Information Needed]"
        },
        "co2_emitted": {
          "type": "string",
          "description": "Estimated carbon emissions.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "hardware_type",
        "hours_used",
        "cloud_provider",
        "cloud_region",
        "co2_emitted"
      ]
    },
    "technicalSpecifications": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_specs": {
          "type": "string",
          "description": "Model architecture and objective details.",
          "default": "[More Information Needed]"
        },
        "compute_infrastructure": {
          "type": "string",
          "description": "Description of the compute infrastructure.",
          "default": "[More Information Needed]"
        },
        "hardware_requirements": {
          "type": "string",
          "description": "Hardware requirements or hardware details.",
          "default": "[More Information Needed]"
        },
        "software": {
          "type": "string",
          "description": "Software stack or software requirements.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "model_specs",
        "compute_infrastructure",
        "hardware_requirements",
        "software"
      ]
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "citation_bibtex": {
          "type": "string",
          "description": "Optional BibTeX citation.",
          "default": "[More Information Needed]"
        },
        "citation_apa": {
          "type": "string",
          "description": "Optional APA citation.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "citation_bibtex",
        "citation_apa"
      ]
    },
    "glossary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "glossary": {
          "type": "string",
          "description": "Optional glossary content.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "glossary"
      ]
    },
    "moreInformation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "more_information": {
          "type": "string",
          "description": "Optional additional information.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "more_information"
      ]
    },
    "modelCardAuthors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_card_authors": {
          "allOf": [
            {
              "$ref": "#/definitions/stringArray"
            }
          ],
          "description": "Optional author or authors of the model card.",
          "default": [
            "[More Information Needed]"
          ]
        }
      },
      "required": [
        "model_card_authors"
      ]
    },
    "modelCardContact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_card_contact": {
          "type": "string",
          "description": "Contact information for the model card.",
          "default": "[More Information Needed]"
        }
      },
      "required": [
        "model_card_contact"
      ]
    }
  },
  "properties": {
    "model_id": {
      "type": "string",
      "description": "Display identifier or name of the model.",
      "default": "Model ID"
    },
    "model_summary": {
      "type": "string",
      "description": "Short summary shown near the top of the model card.",
      "default": ""
    },
    "model_details": {
      "$ref": "#/definitions/modelDetails"
    },
    "uses": {
      "$ref": "#/definitions/uses"
    },
    "bias_risks_and_limitations": {
      "$ref": "#/definitions/biasRisksAndLimitations"
    },
    "how_to_get_started_with_the_model": {
      "$ref": "#/definitions/howToGetStartedWithTheModel"
    },
    "training_details": {
      "$ref": "#/definitions/trainingDetails"
    },
    "evaluation": {
      "$ref": "#/definitions/evaluation"
    },
    "model_examination": {
      "$ref": "#/definitions/modelExamination"
    },
    "environmental_impact": {
      "$ref": "#/definitions/environmentalImpact"
    },
    "technical_specifications": {
      "$ref": "#/definitions/technicalSpecifications"
    },
    "citation": {
      "$ref": "#/definitions/citation"
    },
    "glossary": {
      "$ref": "#/definitions/glossary"
    },
    "more_information": {
      "$ref": "#/definitions/moreInformation"
    },
    "model_card_authors": {
      "$ref": "#/definitions/modelCardAuthors"
    },
    "model_card_contact": {
      "$ref": "#/definitions/modelCardContact"
    }
  },
  "required": [
    "model_id",
    "model_summary",
    "model_details",
    "uses",
    "bias_risks_and_limitations",
    "how_to_get_started_with_the_model",
    "training_details",
    "evaluation",
    "environmental_impact",
    "model_card_contact"
  ],
  "examples": [
    {
      "model_id": "org/example-model",
      "model_summary": "A concise summary of the model.",
      "model_details": {
        "model_description": "A longer description covering what the model does and why it exists.",
        "developers": [
          "Example Research"
        ],
        "funded_by": [
          "Example Grant Program"
        ],
        "shared_by": [
          "Example Hub"
        ],
        "model_type": "text-classification",
        "language": [
          "en"
        ],
        "license": "apache-2.0",
        "base_model": [
          "org/base-model"
        ],
        "model_sources": {
          "repo": "https://example.com/repo",
          "paper": "https://example.com/paper",
          "demo": "https://example.com/demo"
        }
      },
      "uses": {
